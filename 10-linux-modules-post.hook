[Trigger]
Operation = Install
Operation = Upgrade
Type = Path
Target = usr/lib/modules/*/vmlinuz

[Action]
Description = Restoring Linux kernel modules...
When = PostTransaction
Exec = /bin/sh -exc 'cd /usr/lib/modules; KVER=${KVER:-$(uname -r)}; [ -d ".backup/$KVER" -a ! -d "$KVER" ] && mv ".backup/$KVER" "$KVER"; rm -rf .backup'
